# ── Force Subscribe ──────────────────────────────────────────
# FORCE_SUB_CHANNEL : @username  OR  -100xxxxxxxxxx numeric id of your channel
# FORCE_SUB_URL     : Full https://t.me/ link for the "Join Channel" button
# Both are REQUIRED for force-sub to work.
FORCE_SUB_CHANNEL=@YourChannelUsername
FORCE_SUB_URL=https://t.me/YourChannelUsername
